# ─────────────────────────────────────────────────────────────────────────────
# SatoshiBin / PayFile — Environment Configuration
# Copy to .env and fill in your values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Your public domain name (used by Nginx SSL + CORS)
# Leave blank to use self-signed cert on localhost
DOMAIN=yourdomain.com

# Frontend URL (accessible by users)
FRONTEND_URL=http://localhost

# Public URL of the backend (accessible by Bitcart container internally)
BACKEND_URL=http://backend:5000

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/payfile

# ── Security ─────────────────────────────────────────────────────────────────
# Run: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# JWT expiry
JWT_EXPIRES_IN=7d

# ── Admin ────────────────────────────────────────────────────────────────────
OWNER_EMAIL=admin@yourdomain.com

# ── Admin Payout Addresses ───────────────────────────────────────────────────
# Replace with your own cryptocurrency wallet addresses

ADMIN_BTC_ADDRESS=your_bitcoin_mainnet_address
ADMIN_USDT_TRC20_ADDRESS=your_tron_usdt_address
ADMIN_USDT_ERC20_ADDRESS=your_ethereum_usdt_address
# Generic fallback (used if TRC20/ERC20 specific address not set)
ADMIN_USDT_ADDRESS=your_usdt_address_fallback

# ── Bitcart Integration ───────────────────────────────────────────────────────
# Bitcart API is internal — accessed via Docker network name
BITCART_HOST=http://bitcart_api:8000

# Get these from: http://127.0.0.1:4000 (Bitcart Admin Panel)
# 1. Create an account at /register
# 2. Go to Account → Settings → Generate API Key
BITCART_API_KEY=your_bitcart_api_key_here

# 3. Create a Store → copy the Store ID from the URL
BITCART_STORE_ID=your_bitcart_store_id_here

# 4. Create Wallets (one per currency):
#    Wallets → Add Wallet → BTC (mainnet)
BITCART_WALLET_ID=your_btc_wallet_id_here

#    Wallets → Add Wallet → USDTTRX (Tron mainnet)
BITCART_USDT_TRC20_WALLET_ID=your_usdt_trc20_wallet_id_here

#    Wallets → Add Wallet → USDTETH (Ethereum mainnet)
BITCART_USDT_ERC20_WALLET_ID=your_usdt_erc20_wallet_id_here

# Webhook secret — Bitcart signs its callbacks with this
# Run: openssl rand -hex 16
BITCART_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ── Bitcart Database Password ─────────────────────────────────────────────────
# Internal Postgres password for Bitcart (change this in production)
BITCART_DB_PASSWORD=change_this_secure_password

# ── Email (Brevo / Sendinblue) ────────────────────────────────────────────────
# Sign up at https://www.brevo.com and get your API key
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=SatoshiBin

# ── Blockchain Networks ───────────────────────────────────────────────────────
BTC_NETWORK=mainnet
